#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ ! -d "$SCRIPT_DIR/.venv" ]; then
    echo "[setup] Creating virtual environment..."
    python3 -m venv "$SCRIPT_DIR/.venv"
fi

if ! "$SCRIPT_DIR/.venv/bin/python" -c "import cv2" 2>/dev/null; then
    echo "[setup] Installing opencv-python-headless..."
    "$SCRIPT_DIR/.venv/bin/pip" install opencv-python-headless
fi

PYTHON="$SCRIPT_DIR/.venv/bin/python"
SCRIPT="$SCRIPT_DIR/make-avatar.py"

# Separate flags from file paths
flags=()
files=()
for arg in "$@"; do
    if [[ "$arg" == -* ]]; then
        flags+=("$arg")
    else
        files+=("$arg")
    fi
done

if [ ${#files[@]} -eq 0 ]; then
    exec "$PYTHON" "$SCRIPT" ${flags[@]+"${flags[@]}"}
fi

for file in "${files[@]}"; do
    [[ "$(basename "$file")" == *_avatar.* || "$(basename "$file")" == *_debug.* ]] && continue
    "$PYTHON" "$SCRIPT" ${flags[@]+"${flags[@]}"} "$file"
done
