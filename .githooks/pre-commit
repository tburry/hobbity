#!/bin/sh
#
# Pre-commit hook: generate avatars for staged PC and NPC artwork

staged=$(git diff --cached --name-only --diff-filter=ACM -- 'src/assets/images/pcs/*.webp' 'src/assets/images/npcs/*.webp' | grep -v '_avatar\.\|_debug\.')

if [ -z "$staged" ]; then
  exit 0
fi

for file in $staged; do
  scripts/make-avatar "$file"
  base="${file%.*}"
  git add "${base}_avatar.webp"
done
