---
import { Image, getImage } from 'astro:assets';

interface Props {
  name: string;
  class: string;
  level: number;
  avatar: ImageMetadata;
  fullImage?: ImageMetadata;
  link?: string;
  tagline?: string;
  stats: { STR: number; INT: number; WIS: number; DEX: number; CON: number; CHA: number };
  sections?: Record<string, string>;
}

const { name, class: cls, level, avatar, fullImage, link, tagline, stats, sections = {} } = Astro.props;
const fullSrc = fullImage ? (await getImage({ src: fullImage })).src : undefined;
---

<div class="pc-card">
  <div class="pc-card-avatar">
    {fullSrc ? (
      <a href={fullSrc} data-lightbox>
        <Image src={avatar} alt={name} width={240} />
      </a>
    ) : (
      <Image src={avatar} alt={name} width={240} />
    )}
  </div>
  <div class="pc-card-info">
    <h2 id={name.toLowerCase().split(' ')[0]}>{link ? <a href={link}>{name}</a> : name}</h2>
    <p class="pc-card-meta">{cls} &middot; Level {level}</p>
    {tagline && <p class="pc-card-tagline">{tagline}</p>}
    <table class="pc-card-stats stat">
      <thead>
        <tr>
          {Object.keys(stats).map((s) => <th>{s}</th>)}
        </tr>
      </thead>
      <tbody>
        <tr>
          {Object.values(stats).map((v) => <td>{v}</td>)}
        </tr>
      </tbody>
    </table>
  </div>
</div>
{Object.entries(sections).map(([heading, html]) => (
  <div class="pc-card-section">
    <h3>{heading}</h3>
    <Fragment set:html={html} />
  </div>
))}

<style lang="scss">
  .pc-card {
    display: flex;
    gap: var(--space);
    align-items: flex-start;
    margin: calc(var(--space) * 2) 0 var(--space);

    @media (max-width: 500px) {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    &-avatar {
      flex-shrink: 0;

      img {
        border-radius: var(--border-radius);
        width: 240px;
        height: 240px;
        object-fit: cover;
        border: var(--border-width) solid var(--border);

        @media (max-width: 680px) {
          width: 88px;
          height: 88px;
          border-radius: 50%;
        }
      }
    }

    &-info {
      flex: 1;
      min-width: 0;

      h2 {
        margin-top: 0;
      }

      & :last-child {
        margin-bottom: 0;
      }
    }

    &-meta {
      margin: calc(var(--space-sm) * -1) 0 var(--space-sm);
      font-style: italic;
      opacity: 0.8;
    }
  }
</style>
