---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  class: string;
  level: number;
  avatar?: ImageMetadata;
  fullSrc?: string;
  tagline?: string;
  stats: { STR: number; INT: number; WIS: number; DEX: number; CON: number; CHA: number };
}

const { name, class: cls, level, avatar, fullSrc, tagline, stats } = Astro.props;
---

<div class="pc-detail">
  {avatar && (
    <div class="pc-detail-avatar">
      {fullSrc ? (
        <a href={fullSrc} data-lightbox>
          <Image src={avatar} alt={name} width={160} />
        </a>
      ) : (
        <Image src={avatar} alt={name} width={160} />
      )}
    </div>
  )}
  <h1 data-pagefind-weight="10">{name}</h1>
  <p class="pc-detail-meta">{cls} &middot; Level {level}</p>
  <table class="pc-detail-stats stat">
    <thead>
      <tr>
        {Object.keys(stats).map((s) => <th>{s}</th>)}
      </tr>
    </thead>
    <tbody>
      <tr>
        {Object.values(stats).map((v) => <td>{v}</td>)}
      </tr>
    </tbody>
  </table>
</div>

<style lang="scss">
  .pc-detail {
    text-align: center;
    margin: 0 0 var(--space);

    h1 {
      margin: var(--space-sm) 0 0;
    }

    &-avatar {
      margin-bottom: var(--space);

      a {
        display: inline-block;
        line-height: 0;
      }

      img {
        border-radius: 50%;
        width: 160px;
        height: 160px;
        object-fit: cover;
        border: var(--border-width) solid var(--border);

        @media (max-width: 680px) {
          width: 88px;
          height: 88px;
        }
      }
    }

    &-tagline,
    &-meta {
      margin: calc(var(--space-sm) / 2) 0 var(--space-sm);
      font-style: italic;
      opacity: 0.8;
    }

    &-stats {
      margin: 0 auto;
    }
  }
</style>
