---
/**
 * Drop-in lightbox component. Automatically attaches to all <img> elements
 * inside <main>, or to elements with [data-lightbox] attributes.
 *
 * Usage: just include <Lightbox /> anywhere on the page.
 */
import { images as galleryImages } from '../lib/gallery';

// Map alt text → gallery caption and full-size src for cross-referencing
const galleryCaptions: Record<string, string> = {};
const gallerySrcs: Record<string, string> = {};
for (const img of galleryImages) {
  galleryCaptions[img.alt] = img.caption;
  gallerySrcs[img.alt] = img.src.src;
}
---

<div class="lightbox" id="lightbox" data-captions={JSON.stringify(galleryCaptions)} data-srcs={JSON.stringify(gallerySrcs)}>
  <button class="lightbox-close" aria-label="Close">&times;</button>
  <button class="lightbox-prev" aria-label="Previous">&lsaquo;</button>
  <button class="lightbox-next" aria-label="Next">&rsaquo;</button>
  <div class="lightbox-content" id="lightbox-content">
    <img class="lightbox-img" id="lightbox-img" />
    <div class="lightbox-caption" id="lightbox-caption"></div>
  </div>
</div>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const content = document.getElementById('lightbox-content')!;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption')!;
  const galleryCaptions: Record<string, string> = JSON.parse(lightbox.dataset.captions || '{}');
  const gallerySrcs: Record<string, string> = JSON.parse(lightbox.dataset.srcs || '{}');

  interface LightboxItem {
    src: string;
    alt: string;
    caption: string;
    storyLink?: string;
    storyTitle?: string;
  }

  let items: LightboxItem[] = [];
  let current = 0;

  // Collect lightbox items: [data-lightbox] elements or all imgs in main
  const explicit = document.querySelectorAll<HTMLElement>('[data-lightbox]');
  if (explicit.length > 0) {
    explicit.forEach((el) => {
      const img = el.querySelector('img') || el as HTMLImageElement;
      const figure = el.closest('figure');
      const figcaption = figure?.querySelector('figcaption');
      items.push({
        src: el.getAttribute('href') || img.src,
        alt: img.alt || '',
        caption: figcaption?.innerHTML || img.alt || '',
      });
    });
  } else {
    document.querySelectorAll<HTMLImageElement>('main img').forEach((img) => {
      if (img.classList.contains('img-logo') || img.closest('.no-lightbox')) return;
      const alt = img.alt || '';
      items.push({
        src: gallerySrcs[alt] || img.currentSrc || img.src,
        alt,
        caption: galleryCaptions[alt] || alt,
      });
    });
  }

  function captionHtml(item: LightboxItem) {
    let html = item.caption;
    if (item.storyLink && item.storyTitle) {
      html += ` <a class="gallery-link" href="${item.storyLink}">Found in: ${item.storyTitle}</a>`;
    }
    return html;
  }

  function show(i: number, direction?: 'left' | 'right') {
    const next = (i + items.length) % items.length;
    if (direction && next !== current) {
      const sign = direction === 'left' ? -1 : 1;
      content.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
      content.style.transform = `translateX(${sign * 100}px)`;
      content.style.opacity = '0';
      setTimeout(() => {
        current = next;
        lbImg.src = items[current].src;
        lbImg.alt = items[current].alt;
        lbCaption.innerHTML = captionHtml(items[current]);
        content.style.transition = 'none';
        content.style.transform = `translateX(${-sign * 100}px)`;
        content.style.opacity = '0';
        requestAnimationFrame(() => {
          content.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
          content.style.transform = 'translateX(0)';
          content.style.opacity = '1';
        });
      }, 250);
    } else {
      current = next;
      lbImg.src = items[current].src;
      lbImg.alt = items[current].alt;
      lbCaption.innerHTML = captionHtml(items[current]);
      content.style.transition = 'none';
      content.style.transform = 'translateX(0)';
      content.style.opacity = '1';
    }
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  }

  // Attach click handlers
  if (explicit.length > 0) {
    explicit.forEach((el, i) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        show(i);
      });
    });
  } else {
    let idx = 0;
    document.querySelectorAll<HTMLImageElement>('main img').forEach((img) => {
      if (img.classList.contains('img-logo') || img.closest('.no-lightbox')) return;
      const thisIdx = idx++;
      img.style.cursor = 'pointer';
      img.addEventListener('click', () => show(thisIdx));
    });
  }

  lightbox.querySelector('.lightbox-close')!.addEventListener('click', close);
  lightbox.querySelector('.lightbox-prev')!.addEventListener('click', () => show(current - 1, 'right'));
  lightbox.querySelector('.lightbox-next')!.addEventListener('click', () => show(current + 1, 'left'));

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(current - 1, 'right');
    if (e.key === 'ArrowRight') show(current + 1, 'left');
  });

  // Touch/swipe support
  let touchStartX = 0;
  let touchStartY = 0;
  let tracking = false;

  lightbox.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].clientX;
    touchStartY = e.changedTouches[0].clientY;
    tracking = true;
    content.style.transition = 'none';
  }, { passive: true });

  lightbox.addEventListener('touchmove', (e) => {
    if (!tracking) return;
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    if (Math.abs(dy) > Math.abs(dx)) { tracking = false; return; }
    const opacity = Math.max(0.3, 1 - Math.abs(dx) / 300);
    content.style.transform = `translateX(${dx}px)`;
    content.style.opacity = String(opacity);
  }, { passive: true });

  lightbox.addEventListener('touchend', (e) => {
    if (!tracking) {
      content.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
      content.style.transform = 'translateX(0)';
      content.style.opacity = '1';
      return;
    }
    tracking = false;
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) {
      show(dx > 0 ? current - 1 : current + 1, dx > 0 ? 'right' : 'left');
    } else {
      content.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
      content.style.transform = 'translateX(0)';
      content.style.opacity = '1';
    }
  }, { passive: true });
</script>
