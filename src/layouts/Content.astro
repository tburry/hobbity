---
import Base from './Base.astro';

interface Props {
  title?: string;
  class?: string;
}

const { title, class: className } = Astro.props;
---

<Base title={title} showHome={true} searchable={true} lightbox={true}>
  <article class={className}>
    <slot />
  </article>
  <slot name="footer" slot="footer" />
</Base>
