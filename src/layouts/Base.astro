---
interface Props {
  title?: string;
  searchable?: boolean;
  lightbox?: boolean;
}

import '../styles/global.scss';
import { getCollection } from 'astro:content';
import Lightbox from '../components/Lightbox.astro';
import SearchBox from '../components/SearchBox.astro';
import { appendixLabels, worldOrder, appendixOrder } from '../lib/appendix';
import { storyOrder, storySlug, getTitle } from '../lib/stories';

const { title, searchable = false, lightbox = false } = Astro.props;

const essays = await getCollection('essays');
essays.sort((a, b) => a.id.localeCompare(b.id));
const pageTitle = title || 'A Hobbity Adventure';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/hobbity/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/hobbity/icon-192.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/hobbity/apple-touch-icon.png" />
    <link rel="manifest" href="/hobbity/manifest.webmanifest" />
    <meta name="theme-color" content="#2a1f14" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Uncial+Antiqua&family=Crimson+Pro:ital,wght@0,400;0,700;1,400&family=IM+Fell+English:ital@0;1&family=Lora:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="topbar wrap">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <button class="nav-toggle" type="button" aria-label="Navigation">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
        </button>
      </nav>
      <button class="search-toggle" aria-label="Search" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
    </header>

    <div class="page-overlay search-overlay">
      <div class="page-overlay-panel search-overlay-panel">
        <div class="page-overlay-header search-overlay-header wrap">
          <button class="search-toggle" type="button" aria-label="Close search">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <div class="page-overlay-inner search-overlay-inner wrap">
          <h2>Search</h2>
          <SearchBox id="quicksearch" />
        </div>
      </div>
      <button class="btn-floating search-overlay-close" type="button" aria-label="Close search">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="page-overlay nav-overlay">
        <div class="page-overlay-panel nav-overlay-panel">
          <div class="page-overlay-header nav-overlay-header wrap">
            <button class="nav-toggle" type="button" aria-label="Close navigation">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
          <nav class="page-overlay-inner nav-overlay-inner wrap toc">
          <h2>Navigation</h2>
          <ul>
            <li><a href="/hobbity/">Home</a></li>
          </ul>

          <h2>Stories</h2>
          <ul>
            {storyOrder.map((name) => (
              <li><a href={`/hobbity/stories/${storySlug(name)}/`}>{name}</a></li>
            ))}
          </ul>

          {essays.length > 0 && (
            <>
              <h2>Essays</h2>
              <ul>
                {essays.map((e) => (
                  <li><a href={`/hobbity/essays/${e.id}/`}>{getTitle(e)}</a></li>
                ))}
              </ul>
            </>
          )}

          <h2>World</h2>
          <ul>
            {worldOrder.map((id) => (
              <li><a href={`/hobbity/appendix/${id}/`}>{appendixLabels[id]}</a></li>
            ))}
          </ul>

          <h2>Appendices</h2>
          <ul>
            {appendixOrder.map((id) => (
              <li><a href={`/hobbity/appendix/${id}/`}>{appendixLabels[id]}</a></li>
            ))}
            <li><a href="/hobbity/ledger/">Ledger</a></li>
            <li><a href="/hobbity/index-page/">Index</a></li>
          </ul>
          </nav>
        </div>
      </div>

    <main class="wrap" {...(searchable ? { 'data-pagefind-body': '' } : {})}>
      <slot />
    </main>
    <slot name="footer" />
    <footer class="back-to-top-footer">
      <button class="btn-floating back-to-top" type="button" aria-label="Back to top">&uarr; Back to Top</button>
    </footer>
    {lightbox && <Lightbox />}

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        var topbarBtn = document.querySelector('.topbar .search-toggle');
        var overlay = document.querySelector('.search-overlay');
        if (!topbarBtn || !overlay) return;

        var closeBtn = overlay.querySelector('.page-overlay-header .search-toggle');
        var floatingClose = overlay.querySelector('.search-overlay-close');
        var input = document.getElementById('quicksearch-input');
        var results = document.getElementById('quicksearch-results');
        if (input && results && window.initCustomSearch) {
          window.initCustomSearch(input, results);
        }

        var searchIcon = '<circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>';
        var closeIcon = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
        function open() {
          overlay.classList.add('open');
          document.body.style.overflow = 'hidden';
          topbarBtn.querySelector('svg').innerHTML = closeIcon;
          topbarBtn.setAttribute('aria-label', 'Close search');
          if (floatingClose) {
            floatingClose.classList.toggle('visible', overlay.scrollTop > 100);
          }
          if (input && !overlay.scrollTop) {
            setTimeout(function () { input.focus(); }, 50);
          }
        }

        function shut() {
          overlay.classList.remove('open');
          document.body.style.overflow = '';
          topbarBtn.querySelector('svg').innerHTML = searchIcon;
          topbarBtn.setAttribute('aria-label', 'Search');
          if (floatingClose) floatingClose.classList.remove('visible');
        }

        topbarBtn.addEventListener('click', function () {
          overlay.classList.contains('open') ? shut() : open();
        });

        if (closeBtn) closeBtn.addEventListener('click', shut);
        if (floatingClose) floatingClose.addEventListener('click', shut);

        overlay.addEventListener('scroll', function () {
          if (floatingClose) {
            floatingClose.classList.toggle('visible', overlay.scrollTop > 100);
          }
        }, { passive: true });

        overlay.addEventListener('click', function (e) {
          if (e.target === overlay) shut();
          if (e.target.closest('a')) shut();
        });

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && overlay.classList.contains('open')) shut();
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            overlay.classList.contains('open') ? shut() : open();
          }
        });
      });
    </script>
    <script is:inline>
      (function () {
        var topbarBtn = document.querySelector('.topbar .nav-toggle');
        var navOverlay = document.querySelector('.nav-overlay');
        if (!topbarBtn || !navOverlay) return;

        var bookIcon = '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>';
        var closeIcon = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';

        function toggleNav() {
          var isOpen = navOverlay.classList.toggle('open');
          document.body.style.overflow = isOpen ? 'hidden' : '';
          topbarBtn.querySelector('svg').innerHTML = isOpen ? closeIcon : bookIcon;
          topbarBtn.setAttribute('aria-label', isOpen ? 'Close navigation' : 'Navigation');
        }

        document.querySelectorAll('.nav-toggle').forEach(function (btn) {
          btn.addEventListener('click', toggleNav);
        });

        navOverlay.addEventListener('click', function (e) {
          if (e.target === navOverlay) toggleNav();
        });
      })();
    </script>
    <script is:inline>
      (function () {
        // Replace in-page anchor clicks with replaceState so they
        // don't pile up in the history stack
        document.addEventListener('click', function (e) {
          var link = e.target.closest('a[href^="#"]');
          if (!link) return;
          var id = link.getAttribute('href').slice(1);
          var target = document.getElementById(id);
          if (!target) return;
          e.preventDefault();
          history.replaceState(null, '', '#' + id);
          target.scrollIntoView();
        });

        var btn = document.querySelector('.back-to-top');
        if (!btn) return;

        window.addEventListener('scroll', function () {
          btn.classList.toggle('visible', window.scrollY > window.innerHeight);
        }, { passive: true });

        btn.addEventListener('click', function () {
          history.replaceState(null, '', window.location.pathname + window.location.search);
          window.scrollTo(0, 0);
        });
      })();
    </script>
  </body>
</html>
