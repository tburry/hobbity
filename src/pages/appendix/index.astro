---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { appendixLabels, worldOrder, appendixOrder } from '../../lib/appendix';

const pcs = (await getCollection('pcs')).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Appendix">
  <h1>Appendices</h1>

  <h2 id="world">World</h2>
  <ul>
    {worldOrder.map((id) => (
      <li>
        <a href={`/hobbity/world/${id}/`}>{appendixLabels[id]}</a>
        {id === 'pcs' && (
          <ul>
            {pcs.map((pc) => (
              <li><a href={`/hobbity/world/pcs/${pc.id}/`}>{pc.data.name}</a></li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>

  <h2 id="appendices">Appendices</h2>
  <ul>
    {appendixOrder.map((id) => (
      <li>
        <a href={`/hobbity/appendix/${id}/`}>{appendixLabels[id]}</a>
      </li>
    ))}
  </ul>
</Base>
