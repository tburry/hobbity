---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { appendixLabels, appendixOrder } from '../../lib/appendix';

const pcs = (await getCollection('pcs')).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Appendix" showHome={true}>
  <h1>Appendices</h1>
  <ul>
    {appendixOrder.map((id) => (
      <li>
        <a href={`/hobbity/appendix/${id}/`}>{appendixLabels[id]}</a>
        {id === 'pcs' && (
          <ul>
            {pcs.map((pc) => (
              <li><a href={`/hobbity/appendix/pcs/${pc.id}/`}>{pc.data.name}</a></li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
</Base>
