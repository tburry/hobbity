---
import { Image, getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

// --- PC tokens: all levels, grouped by level ---
const pcImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/pcs/*_token.webp',
  { eager: true },
);

const pcs = (await getCollection('pcs')).sort((a, b) => a.data.order - b.data.order);

// Collect all levels that have at least one token
const allLevels = new Set<number>();
for (const key of Object.keys(pcImages)) {
  const m = key.match(/-lvl(\d+)_token\.webp$/);
  if (m) allLevels.add(Number(m[1]));
}
const levels = [...allLevels].sort((a, b) => b - a);

// Build tokens per level
const pcTokensByLevel = await Promise.all(
  levels.map(async (level) => {
    const tokens = await Promise.all(
      pcs.map(async (pc) => {
        const key = `/src/assets/images/pcs/${pc.data.pc}-lvl${level}_token.webp`;
        const src = pcImages[key]?.default;
        if (!src) return null;
        const full = await getImage({ src });
        return { name: pc.data.name, href: `/hobbity/world/pcs/${pc.id}/`, src, fullSrc: full.src };
      }),
    );
    return { level, tokens: tokens.filter(Boolean) as { name: string; href: string; src: ImageMetadata; fullSrc: string }[] };
  }),
);
const pcLevels = pcTokensByLevel.filter((g) => g.tokens.length > 0);

// --- NPC tokens ---
const npcImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/npcs/*_token.webp',
  { eager: true },
);

// Derive NPC display names and dead status from npcs.mdx
const npcsEntry = (await getCollection('world')).find((e) => e.id === 'npcs');
const npcAvatarNames: Record<string, string> = {};
const deadNpcs = new Set<string>();
if (npcsEntry?.body) {
  // Match <NpcAvatar src="slug" alt="Name" />
  for (const m of npcsEntry.body.matchAll(/<NpcAvatar\s+src="([^"]+)"\s+alt="([^"]+)"/g)) {
    npcAvatarNames[m[1]] = m[2];
  }
  // Match ### Name **†** headings to find dead NPCs
  for (const m of npcsEntry.body.matchAll(/^###\s+(.+?)\s+\*\*†\*\*/gm)) {
    const name = m[1];
    // Find the slug for this name
    for (const [slug, n] of Object.entries(npcAvatarNames)) {
      if (n === name) deadNpcs.add(slug);
    }
  }
}

const npcTokens = await Promise.all(
  Object.entries(npcImages).map(async ([path, mod]) => {
    const stem = path.replace(/.*\//, '').replace('_token.webp', '');
    const name = npcAvatarNames[stem] || stem;
    const full = await getImage({ src: mod.default });
    return { name, href: `/hobbity/world/npcs/#${stem}`, dead: deadNpcs.has(stem), src: mod.default, fullSrc: full.src };
  }),
);
const sortKey = (name: string) => name.split(' ').pop()!;
npcTokens.sort((a, b) => sortKey(a.name).localeCompare(sortKey(b.name)));
const aliveNpcs = npcTokens.filter((t) => !t.dead);
const deadNpcTokens = npcTokens.filter((t) => t.dead);
---

<Base title="Tokens">
  <svg xmlns="http://www.w3.org/2000/svg" style="display:none">
    <symbol id="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
    </symbol>
  </svg>

  <h1 data-pagefind-body>Tokens</h1>

  <h2 id="pcs">PCs</h2>
  {pcLevels.map((group, i) => (
    <details open={i === 0 ? true : undefined}>
      <summary><h3 id={`level-${group.level}`}>Level {group.level}</h3></summary>
      <div class="token-grid no-lightbox">
        {group.tokens.map((t) => (
          <figure class="token-figure">
            <button class="token-wrap" data-url={t.fullSrc} title="Copy image URL">
              <Image src={t.src} alt={t.name} width={128} loading="lazy" />
              <span class="token-copy-icon">
                <svg width="20" height="20"><use href="#icon-copy" /></svg>
              </span>
            </button>
            <figcaption><a href={t.href}>{t.name}</a></figcaption>
          </figure>
        ))}
      </div>
    </details>
  ))}

  <h2 id="npcs">NPCs</h2>
  <details open>
    <summary><h3 id="alive">Alive</h3></summary>
    <div class="token-grid no-lightbox">
      {aliveNpcs.map((t) => (
        <figure class="token-figure">
          <button class="token-wrap" data-url={t.fullSrc} title="Copy image URL">
            <Image src={t.src} alt={t.name} width={128} loading="lazy" />
            <span class="token-copy-icon">
              <svg width="20" height="20"><use href="#icon-copy" /></svg>
            </span>
          </button>
          <figcaption><a href={t.href}>{t.name}</a></figcaption>
        </figure>
      ))}
    </div>
  </details>
  {deadNpcTokens.length > 0 && (
    <details>
      <summary><h3 id="dead">Dead</h3></summary>
      <div class="token-grid no-lightbox">
        {deadNpcTokens.map((t) => (
          <figure class="token-figure">
            <button class="token-wrap" data-url={t.fullSrc} title="Copy image URL">
              <Image src={t.src} alt={t.name} width={128} loading="lazy" />
              <span class="token-copy-icon">
                <svg width="20" height="20"><use href="#icon-copy" /></svg>
              </span>
            </button>
            <figcaption><a href={t.href}>{t.name}</a></figcaption>
          </figure>
        ))}
      </div>
    </details>
  )}
</Base>

<style>
  .token-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    @media (min-width: 600px) {
      grid-template-columns: repeat(auto-fill, minmax(128px, 1fr));
    }
    gap: var(--space);
  }

  .token-figure {
    margin: 0;
    text-align: center;
  }

  .token-wrap {
    position: relative;
    display: block;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .token-wrap img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 50%;
  }

  .token-copy-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.15s;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .token-wrap:hover .token-copy-icon {
    opacity: 1;
  }

  .token-wrap:active .token-copy-icon {
    background: rgba(0, 0, 0, 0.8);
  }

  figcaption {
    /* margin-top: 0.4rem; */
    font-size: 0.85em;
  }
</style>

<script>
  const toast = document.createElement('div');
  Object.assign(toast.style, {
    position: 'fixed',
    bottom: '1.5rem',
    left: '50%',
    transform: 'translateX(-50%)',
    background: 'rgba(0, 0, 0, 0.8)',
    color: '#fff',
    padding: '0.5rem 1rem',
    borderRadius: '0.5rem',
    fontSize: '0.85em',
    pointerEvents: 'none',
    opacity: '0',
    transition: 'opacity 0.2s',
    zIndex: '100',
  });
  document.body.appendChild(toast);
  let toastTimer: ReturnType<typeof setTimeout>;

  function showToast(msg: string) {
    toast.textContent = msg;
    toast.style.opacity = '1';
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => (toast.style.opacity = '0'), 1500);
  }

  document.querySelectorAll<HTMLButtonElement>('.token-wrap').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      const fullUrl = new URL(url, window.location.origin).href;
      await navigator.clipboard.writeText(fullUrl);
      showToast('Token URL copied');
    });
  });
</script>
