---
import Base from '../../layouts/Base.astro';
import { images } from '../../lib/gallery';
---

<Base title="Appendix D: Gallery" showHome={true} searchable={true}>
  <div class="gallery-page">
  <h1>Gallery</h1>

  <div class="gallery">
    {images.map((img, i) => (
      <figure>
        <a href={img.src} data-lightbox={i}>
          <picture>
            <source media="(max-width: 720px)" srcset={img.srcSmall} />
            <img src={img.src} alt={img.alt} loading="lazy" />
          </picture>
        </a>
        <figcaption>
          {img.caption}
          {img.storyLink && img.storyTitle && (
            <a class="gallery-link" href={img.storyLink}>
              Found in: {img.storyTitle}
            </a>
          )}
        </figcaption>
      </figure>
    ))}
  </div>
  </div>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <button class="lightbox-prev" aria-label="Previous">&lsaquo;</button>
    <button class="lightbox-next" aria-label="Next">&rsaquo;</button>
    <div class="lightbox-content" id="lightbox-content">
      <img class="lightbox-img" id="lightbox-img" />
      <div class="lightbox-caption" id="lightbox-caption"></div>
    </div>
  </div>
</Base>

<script define:vars={{ images }}>
  const lightbox = document.getElementById('lightbox');
  const content = document.getElementById('lightbox-content');
  const lbImg = document.getElementById('lightbox-img');
  const lbCaption = document.getElementById('lightbox-caption');
  let current = 0;

  function captionHtml(img) {
    let html = img.caption;
    if (img.storyLink && img.storyTitle) {
      html += ` <a class="gallery-link" href="${img.storyLink}">Found in: ${img.storyTitle}</a>`;
    }
    return html;
  }

  function show(i, direction) {
    const next = (i + images.length) % images.length;
    if (direction && next !== current) {
      const sign = direction === 'left' ? -1 : 1;
      content.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
      content.style.transform = `translateX(${sign * 100}px)`;
      content.style.opacity = '0';
      setTimeout(() => {
        current = next;
        lbImg.src = images[current].src;
        lbImg.alt = images[current].alt;
        lbCaption.innerHTML = captionHtml(images[current]);
        content.style.transition = 'none';
        content.style.transform = `translateX(${-sign * 100}px)`;
        content.style.opacity = '0';
        requestAnimationFrame(() => {
          content.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
          content.style.transform = 'translateX(0)';
          content.style.opacity = '1';
        });
      }, 250);
    } else {
      current = next;
      lbImg.src = images[current].src;
      lbImg.alt = images[current].alt;
      lbCaption.innerHTML = captionHtml(images[current]);
      content.style.transition = 'none';
      content.style.transform = 'translateX(0)';
      content.style.opacity = '1';
    }
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-lightbox]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      show(parseInt(a.dataset.lightbox));
    });
  });

  lightbox.querySelector('.lightbox-close').addEventListener('click', close);
  lightbox.querySelector('.lightbox-prev').addEventListener('click', () => show(current - 1, 'right'));
  lightbox.querySelector('.lightbox-next').addEventListener('click', () => show(current + 1, 'left'));

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(current - 1, 'right');
    if (e.key === 'ArrowRight') show(current + 1, 'left');
  });

  let touchStartX = 0;
  let touchStartY = 0;
  let tracking = false;

  lightbox.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].clientX;
    touchStartY = e.changedTouches[0].clientY;
    tracking = true;
    content.style.transition = 'none';
  }, { passive: true });

  lightbox.addEventListener('touchmove', (e) => {
    if (!tracking) return;
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    if (Math.abs(dy) > Math.abs(dx)) { tracking = false; return; }
    const opacity = Math.max(0.3, 1 - Math.abs(dx) / 300);
    content.style.transform = `translateX(${dx}px)`;
    content.style.opacity = opacity;
  }, { passive: true });

  lightbox.addEventListener('touchend', (e) => {
    if (!tracking) {
      content.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
      content.style.transform = 'translateX(0)';
      content.style.opacity = '1';
      return;
    }
    tracking = false;
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) {
      show(dx > 0 ? current - 1 : current + 1, dx > 0 ? 'right' : 'left');
    } else {
      content.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
      content.style.transform = 'translateX(0)';
      content.style.opacity = '1';
    }
  }, { passive: true });
</script>
