---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const essays = await getCollection('essays');
essays.sort((a, b) => a.id.localeCompare(b.id));
---

<Base title="Essays" showHome={true}>
  <h1>Essays</h1>
  {essays.length === 0 ? (
    <p>Coming soon.</p>
  ) : (
    <ul class="essay-list">
      {essays.map((essay) => {
        const lines = essay.body?.split('\n') || [];
        const h1 = lines.find((l) => l.startsWith('# '));
        const title = h1 ? h1.replace(/^# /, '') : essay.id;
        return (
          <li>
            <a href={`/hobbity/essays/${essay.id}/`}>{title}</a>
          </li>
        );
      })}
    </ul>
  )}
</Base>
