---
import { getCollection } from 'astro:content';
import Content from '../layouts/Content.astro';

const allStories = await getCollection('stories');

// --- Enemy parsing utilities ---

const STATUSES = ['killed', 'subdued', 'fled', 'evaded'] as const;
type Status = typeof STATUSES[number];
type Tally = Record<Status, number>;

/** Map synonyms to canonical status names. */
const STATUS_ALIASES: Record<string, Status> = { bypassed: 'evaded' };

function emptyTally(): Tally {
  return { killed: 0, subdued: 0, fled: 0, evaded: 0 };
}

/** True if this entry refers to a named NPC rather than a generic monster.
 *  Monsters start with a number (e.g. "6 Goblins"). NPCs are linked or
 *  have no count prefix (e.g. "Abramo (killed)"). */
function isNpc(entry: string): boolean {
  if (entry.includes('/npcs/')) return true;
  const name = entry.replace(/\s*\(.*$/, '').trim();
  if (/^\d/.test(name) || /^multiple\b/i.test(name)) return false;
  return true;
}

/** Find the canonical key for a type, merging singular/plural variants.
 *  Keys preserve the original casing from frontmatter. */
function canonicalKey(type: string, existing: Map<string, Tally>): string {
  const t = type.trim();
  const tLow = t.toLowerCase();
  for (const key of existing.keys()) {
    const kLow = key.toLowerCase();
    if (kLow === tLow) return key;
    if (kLow + 's' === tLow || tLow + 's' === kLow) return key;
    if (kLow.replace(/ves$/, 'f') === tLow || tLow.replace(/ves$/, 'f') === kLow) return key;
  }
  return t;
}

/** Pluralise a lowercase type string. */
function pluralise(s: string): string {
  if (s.endsWith('s') || s.endsWith('x') || s.endsWith('sh') || s.endsWith('ch')) return s + 'es';
  if (s.endsWith('y') && !/[aeiou]y$/.test(s)) return s.slice(0, -1) + 'ies';
  if (s.endsWith('f') && !s.endsWith('ff')) return s.slice(0, -1) + 'ves';
  return s + 's';
}

/** True if the string already looks plural (ends in s/es/ves/ies but not ss). */
function looksPlural(s: string): boolean {
  return /(?:[^s]s|ves|ies)$/.test(s);
}

/** Pluralise a type key for display. Casing is preserved from frontmatter. */
function displayName(key: string): string {
  return looksPlural(key) ? key : pluralise(key);
}

function parseEntry(entry: string): { type: string; tally: Tally } | null {
  const tally = emptyTally();

  // Separate name from parenthetical
  const m = entry.match(/^(.+?)(?:\s*\((.+)\))?$/);
  if (!m) return null;
  const raw = m[1].trim();
  const paren = m[2]?.trim();

  // Extract count and creature type
  const cm = raw.match(/^(\d+)\s+(.+)$/);
  const count = cm ? parseInt(cm[1]) : 0;
  const type = (cm ? cm[2] : raw.replace(/^multiple\s+/i, '')).trim();

  if (!paren) {
    // No parenthetical → all killed
    tally.killed = count;
  } else {
    // Look for "N status" patterns in the parenthetical
    const allStatuses = [...STATUSES, ...Object.keys(STATUS_ALIASES)];
    const statusPattern = new RegExp(`(\\d+)\\s+(${allStatuses.join('|')})`, 'gi');
    const breakdowns: [number, Status][] = [];
    let bm;
    while ((bm = statusPattern.exec(paren)) !== null) {
      const raw = bm[2].toLowerCase();
      const status = (STATUS_ALIASES[raw] || raw) as Status;
      breakdowns.push([parseInt(bm[1]), status]);
    }

    if (breakdowns.length > 0) {
      for (const [n, s] of breakdowns) tally[s] += n;
    } else {
      // Simple status word: "(bypassed)", "(evaded)"
      const raw = paren.replace(/,.*/, '').trim().toLowerCase();
      const simple = (STATUS_ALIASES[raw] || raw) as Status;
      if (STATUSES.includes(simple)) {
        tally[simple] = count || 1;
      } else {
        // Unknown paren (flavour text) → default killed
        tally.killed = count;
      }
    }
  }

  return { type, tally };
}

// --- Tally all enemies across stories ---

const enemies = new Map<string, Tally>();

for (const story of allStories) {
  for (const entry of story.data.enemiesDefeated || []) {
    if (isNpc(entry)) continue;
    const parsed = parseEntry(entry);
    if (!parsed) continue;

    const key = canonicalKey(parsed.type, enemies);
    const existing = enemies.get(key) || emptyTally();
    for (const s of STATUSES) existing[s] += parsed.tally[s];
    enemies.set(key, existing);
  }
}

// Sort alphabetically by display name
const sorted = [...enemies.entries()]
  .map(([type, tally]) => {
    const total = STATUSES.reduce((sum, s) => sum + tally[s], 0);
    return { type, tally, total };
  })
  .sort((a, b) => displayName(a.type).localeCompare(displayName(b.type)));

// Only show status columns that have at least one entry
const activeStatuses = STATUSES.filter((s) =>
  sorted.some((row) => row.tally[s] > 0)
);

---

<Content title="Ledger">
  <h1>Ledger</h1>

  <h2>Magic Items</h2>

  <table>
    <thead>
      <tr>
        <th>Item</th>
        <th>Holder</th>
        <th>Source</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Animal Whistle</td>
        <td><a href="/hobbity/world/pcs/wedge/">Wedge</a></td>
        <td>Bought from <a href="/hobbity/world/npcs/#farmer-fallow">Farmer Fallow</a> – <a href="/hobbity/stories/2025-11-06-the-gomwick-harvest-festival/#the-old-road-to-gomwick">The Gomwick Harvest Festival</a></td>
      </tr>
      <tr>
        <td>Mysterious Stockings</td>
        <td><a href="/hobbity/world/pcs/turnip/">Turnip</a></td>
        <td>Bought from <a href="/hobbity/world/npcs/#farmer-fallow">Farmer Fallow</a> – <a href="/hobbity/stories/2025-11-06-the-gomwick-harvest-festival/#the-old-road-to-gomwick">The Gomwick Harvest Festival</a></td>
      </tr>
      <tr>
        <td>Ring of Protection +1</td>
        <td><a href="/hobbity/world/pcs/wedge/">Wedge</a></td>
        <td>Looted from <a href="/hobbity/world/npcs/#misha">Misha</a> – <a href="/hobbity/stories/2026-03-31-the-serpent-beneath/#prisoner-of-the-snake-goddess">The Serpent Beneath</a></td>
      </tr>
      <tr>
        <td>Scale Mail +1</td>
        <td><a href="/hobbity/world/pcs/turnip/">Turnip</a></td>
        <td>Looted from <a href="/hobbity/world/npcs/#abramo">Abramo</a> – <a href="/hobbity/stories/2026-03-31-the-serpent-beneath/#prisoner-of-the-snake-goddess">The Serpent Beneath</a></td>
      </tr>
      <tr>
        <td>Three-Feathered Hat</td>
        <td><a href="/hobbity/world/pcs/boffo/">Boffo</a></td>
        <td>Bought from <a href="/hobbity/world/npcs/#farmer-fallow">Farmer Fallow</a> – <a href="/hobbity/stories/2025-11-06-the-gomwick-harvest-festival/#the-old-road-to-gomwick">The Gomwick Harvest Festival</a></td>
      </tr>
    </tbody>
  </table>

  <h2>Consumables</h2>

  <table>
    <thead>
      <tr>
        <th>Item</th>
        <th class="num">Used</th>
        <th class="num">Left</th>
      </tr>
    </thead>
    <tbody>
      <tr class="spent">
        <td>Brooch of Shielding</td>
        <td class="num">1</td>
        <td class="num">0</td>
      </tr>
      <tr class="spent">
        <td>Potion of Growth</td>
        <td class="num">1</td>
        <td class="num">0</td>
      </tr>
      <tr class="spent">
        <td>Potion of Healing</td>
        <td class="num">7</td>
        <td class="num">0</td>
      </tr>
      <tr class="spent">
        <td>Potion of Speed</td>
        <td class="num">1</td>
        <td class="num">0</td>
      </tr>
      <tr class="spent">
        <td>Scroll of Dispel Magic</td>
        <td class="num">1</td>
        <td class="num">0</td>
      </tr>
      <tr class="spent">
        <td>Scroll of Sleep</td>
        <td class="num">1</td>
        <td class="num">0</td>
      </tr>
      <tr class="spent">
        <td>Scroll of Wizard Lock</td>
        <td class="num">1</td>
        <td class="num">0</td>
      </tr>
      <tr class="spent">
        <td>Sling Bullet of Phantasmal Force</td>
        <td class="num">1</td>
        <td class="num">0</td>
      </tr>
      <tr class="spent">
        <td>Sling Bullet of Sleep</td>
        <td class="num">1</td>
        <td class="num">0</td>
      </tr>
      <tr class="spent">
        <td>Sling Bullets +1</td>
        <td class="num">4</td>
        <td class="num">0</td>
      </tr>
    </tbody>
  </table>

  <h2>Enemies Defeated</h2>

  <table>
    <thead>
      <tr>
        <th>Enemy</th>
        {activeStatuses.map((s) => (
          <th class="num vertical">{s.charAt(0).toUpperCase() + s.slice(1)}</th>
        ))}
        <th class="num vertical">Total</th>
      </tr>
    </thead>
    <tbody>
      {sorted.map((row) => (
        <tr>
          <td>{displayName(row.type)}</td>
          {activeStatuses.map((s) => <td class="num">{row.tally[s] || <span class="muted">-</span>}</td>)}
          <td class="num">{row.total}</td>
        </tr>
      ))}
    </tbody>
    <tfoot>
      <tr>
        <th>Total</th>
        {activeStatuses.map((s) => (
          <th class="num">{sorted.reduce((sum, row) => sum + row.tally[s], 0) || <span class="muted">-</span>}</th>
        ))}
        <th class="num">{sorted.reduce((sum, row) => sum + row.total, 0)}</th>
      </tr>
    </tfoot>
  </table>

</Content>
