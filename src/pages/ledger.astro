      </tr>
      <tr>
        <td>Ring of Protection +1</td>
        <td><a href="/hobbity/appendix/pcs/wedge/">Wedge</a></td>
        <td>Looted from <a href="/hobbity/appendix/npcs/#misha">Misha</a> — <a href="/hobbity/stories/2026-03-31-the-serpent-beneath/#prisoner-of-the-snake-goddess">The Serpent Beneath</a></td>
      </tr>
      <tr>
        <td>Scale Mail +1</td>
        <td><a href="/hobbity/appendix/pcs/turnip/">Turnip</a></td>
        <td>Looted from <a href="/hobbity/appendix/npcs/#abramo">Abramo</a> — <a href="/hobbity/stories/2026-03-31-the-serpent-beneath/#prisoner-of-the-snake-goddess">The Serpent Beneath</a></td>
      </tr>
      <tr>
        <td>Three-Feathered Hat</td>
        <td><a href="/hobbity/appendix/pcs/boffo/">Boffo</a></td>
        <td>Bought from <a href="/hobbity/appendix/npcs/#farmer-fallow">Farmer Fallow</a> — <a href="/hobbity/stories/2025-11-06-the-gomwick-harvest-festival/#the-old-road-to-gomwick">The Gomwick Harvest Festival</a></td>
      </tr>
    </tbody>
  </table>

