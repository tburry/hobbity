---
import { getCollection, render } from 'astro:content';
import Content from '../../layouts/Content.astro';
import { storySlug, getTitle, toShireDate, mdLinks } from '../../lib/stories';

export async function getStaticPaths() {
  const allStories = await getCollection('stories');
  allStories.sort((a, b) => a.id.localeCompare(b.id));

  return allStories.map((story, i) => {
    const siblings = allStories.filter((s) => s.data.story === story.data.story);
    const idx = siblings.findIndex((s) => s.id === story.id);

    return {
      params: { id: story.id },
      props: {
        story,
        prev: idx > 0 ? siblings[idx - 1] : null,
        next: idx < siblings.length - 1 ? siblings[idx + 1] : null,
      },
    };
  });
}

const { story, prev, next } = Astro.props;
const storyGroupSlug = storySlug(story.data.story);
const { Content: StoryContent } = await render(story);
const title = getTitle(story);
const date = story.data.date ? toShireDate(story.data.date) : null;
const pcs = story.data.pcs || [];
const location = story.data.location;
---

<Content title={title}>
  <h1>{title}</h1>

  <aside data-pagefind-ignore>
  <ul>
    <li><strong>Told on:</strong>
    {date && (
      <time datetime={story.data.date.toISOString().split('T')[0]} title={date.real} data-pagefind-sort="date[datetime]">{date.shire}</time>
    )}
    </li>
    <li><strong>PCs:</strong>
      <ul>
        {pcs.map((pc) => (
          <li><a href={`/hobbity/appendix/pcs/${pc.slug}/`}>{pc.name}</a> – Level {pc.level} Adventurer</li>
        ))}
      </ul>
    </li>
    {location && <li><strong>Location:</strong> <Fragment set:html={mdLinks(location)} /></li>}
  </ul>
  </aside>

  <StoryContent />

  <footer class="chapter-nav" slot="footer">
    {prev ? (
      <a href={`/hobbity/stories/${prev.id}/`} class="prev">
        &larr; {getTitle(prev)}
      </a>
    ) : (
      <a href={`/hobbity/stories/${storyGroupSlug}/`} class="prev">
        &larr; {story.data.story}
      </a>
    )}
    {next ? (
      <a href={`/hobbity/stories/${next.id}/`} class="next">
        {getTitle(next)} &rarr;
      </a>
    ) : (
      <a href="/hobbity/" class="next">
        Home &#10086;
      </a>
    )}
  </footer>
</Content>
