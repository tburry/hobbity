---
import { getCollection } from 'astro:content';
import GithubSlugger from 'github-slugger';
import Base from '../layouts/Base.astro';
import TocNav from '../components/TocNav.astro';
import { tocSections, type TocSection, type TocItem } from '../lib/toc';
import { getTitle } from '../lib/stories';

const allStories = await getCollection('stories');
allStories.sort((a, b) => a.id.localeCompare(b.id));

const pcs = (await getCollection('pcs')).sort((a, b) => a.data.order - b.data.order);

const worldCollection = await getCollection('world');
const places = worldCollection.find((e) => e.id === 'places');
const slugger = new GithubSlugger();

// Children indexed by parent href. Entries with `ordered: true` render as <ol>.
const childrenByHref: Record<string, { children: TocItem[]; ordered?: boolean }> = {
  // Story groups → individual chapters
  ...Object.fromEntries(
    tocSections[0].items.map((item) => {
      const chapters = allStories.filter((s) =>
        item.href.endsWith(`/${s.data.story.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`)
      );
      return [item.href, {
        children: chapters.map((ch) => ({ label: getTitle(ch), href: `/hobbity/stories/${ch.id}/` })),
        ordered: true,
      }];
    })
  ),

  // PCs
  '/hobbity/world/pcs/': {
    children: pcs.map((pc) => ({ label: pc.data.name, href: `/hobbity/world/pcs/${pc.id}/` })),
  },

  // Places → h2 headings
  '/hobbity/world/places/': {
    children: (places?.body?.match(/^## .+/gm) ?? []).map((h2) => {
      const label = h2.replace(/^## /, '');
      return { label, href: `/hobbity/world/places/#${slugger.slug(label)}` };
    }),
  },

  // Ledger sections
  '/hobbity/ledger/': {
    children: [
      { label: 'Magic Items', href: '/hobbity/ledger/#magic-items' },
      { label: 'Consumables', href: '/hobbity/ledger/#consumables' },
      { label: 'Enemies Defeated', href: '/hobbity/ledger/#enemies-defeated' },
    ],
  },
};

const sections: TocSection[] = tocSections.map((section) => ({
  ...section,
  items: section.items
    .filter((item) => item.href !== '/hobbity/index-page/')
    .map((item) => {
      const extra = childrenByHref[item.href];
      if (extra?.children.length) return { ...item, ...extra };
      return item;
    }),
}));
---

<Base title="Index">
  <h1 data-pagefind-body>Index</h1>
  <TocNav sections={sections} />
</Base>
