---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { appendixLabels, worldOrder, appendixOrder } from '../lib/appendix';
import { storyOrder, storySlug, getTitle } from '../lib/stories';

const allStories = await getCollection('stories');
allStories.sort((a, b) => a.id.localeCompare(b.id));

const essays = await getCollection('essays');
essays.sort((a, b) => a.id.localeCompare(b.id));

const pcs = (await getCollection('pcs')).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Index" showHome={true}>
  <h1>Index</h1>

  <h2>Stories</h2>
  {storyOrder.map((name) => {
    const chapters = allStories.filter((s) => s.data.story === name);
    return (
      <>
        <h3><a href={`/hobbity/stories/${storySlug(name)}/`}>{name}</a></h3>
        <ol>
          {chapters.map((ch) => (
            <li><a href={`/hobbity/stories/${ch.id}/`}>{getTitle(ch)}</a></li>
          ))}
        </ol>
      </>
    );
  })}

  {essays.length > 0 && (
    <>
      <h2>Essays</h2>
      <ul>
        {essays.map((e) => (
          <li><a href={`/hobbity/essays/${e.id}/`}>{getTitle(e)}</a></li>
        ))}
      </ul>
    </>
  )}

  <h2>World</h2>
  <ul>
    {worldOrder.map((id) => (
      <li>
        <a href={`/hobbity/appendix/${id}/`}>{appendixLabels[id]}</a>
        {id === 'pcs' && (
          <ul>
            {pcs.map((pc) => (
              <li><a href={`/hobbity/appendix/pcs/${pc.id}/`}>{pc.data.name}</a></li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>

  <h2>Appendix</h2>
  <ul>
    {appendixOrder.map((id) => (
      <li>
        <a href={`/hobbity/appendix/${id}/`}>{appendixLabels[id]}</a>
      </li>
    ))}
  </ul>
</Base>
