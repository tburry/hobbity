---
import { getCollection } from 'astro:content';
import GithubSlugger from 'github-slugger';
import Base from '../layouts/Base.astro';
import TocNav from '../components/TocNav.astro';
import { tocSections, type TocSection } from '../lib/toc';
import { getTitle } from '../lib/stories';

const allStories = await getCollection('stories');
allStories.sort((a, b) => a.id.localeCompare(b.id));

const pcs = (await getCollection('pcs')).sort((a, b) => a.data.order - b.data.order);

const storyChildren = Object.fromEntries(
  tocSections[0].items.map((item) => {
    const chapters = allStories.filter((s) =>
      item.href.endsWith(`/${s.data.story.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`)
    );
    return [item.href, chapters.map((ch) => ({
      label: getTitle(ch),
      href: `/hobbity/stories/${ch.id}/`,
    }))];
  })
);

const pcChildren = pcs.map((pc) => ({
  label: pc.data.name,
  href: `/hobbity/appendix/pcs/${pc.id}/`,
}));

const appendix = await getCollection('appendix');
const places = appendix.find((e) => e.id === 'places');
const slugger = new GithubSlugger();
const placeChildren = (places?.body?.match(/^## .+/gm) ?? []).map((h2) => {
  const label = h2.replace(/^## /, '');
  return { label, href: `/hobbity/appendix/places/#${slugger.slug(label)}` };
});

const sections: TocSection[] = tocSections.map((section) => ({
  ...section,
  items: section.items
    .filter((item) => item.href !== '/hobbity/index-page/')
    .map((item) => {
      if (storyChildren[item.href]?.length) {
        return { ...item, children: storyChildren[item.href], ordered: true };
      }
      if (item.href === '/hobbity/appendix/pcs/') {
        return { ...item, children: pcChildren };
      }
      if (item.href === '/hobbity/appendix/places/') {
        return { ...item, children: placeChildren };
      }
      return item;
    }),
}));
---

<Base title="Index">
  <h1 data-pagefind-body>Index</h1>
  <TocNav sections={sections} />
</Base>
